---
layout: null
---
[
  {% for post in site.posts %}
  {
    "title"    : "{{ post.title | escape }}",
    "url"      : "{{ site.baseurl }}{{ post.url }}",
    "category" : "技術文章",
    "date"     : "{{ post.date | date: "%Y-%m-%d" }}",
    "content"  : "{{ post.content | strip_html | strip_newlines | escape | truncatewords: 50 }}"
  } {% if forloop.last == false %},{% endif %}
  {% endfor %}
  
  {% if site.posts.size > 0 and site.pages.size > 0 %},{% endif %}

  {% for page in site.pages %}
  {% if page.title and page.search != false %}
  {
    "title"    : "{{ page.title | escape }}",
    "url"      : "{{ site.baseurl }}{{ page.url }}",
    "category" : "快速指南",
    "date"     : "2026-04-16",
    "content"  : "{{ page.content | strip_html | strip_newlines | escape | truncatewords: 50 }}"
  } {% if forloop.last == false %},{% endif %}
  {% endif %}
  {% endfor %}
]
